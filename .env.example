# WordPress media base for static image URLs (see src/lib/wpAssetBase.js)
VITE_WP_ORIGIN=https://your-site.local

# Sanity — leave empty to use static seeds only; set all three to load homepage from CMS
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01
# VITE_SANITY_USE_CDN=false

# Enquiry form POST target (default: /api/enquiry — proxied to dev API or Netlify function)
# VITE_ENQUIRY_API_URL=/api/enquiry

# Production enquiry integrations (Netlify function `enquiry.mjs`)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=enquiries@yourdomain.com
# RESEND_TO_EMAIL=hello@yourdomain.com
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_WRITE_TOKEN=
